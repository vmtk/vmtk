 .gitignore                                                                     
*~
.idea
__pycache__
*.pyc
.cache
.DS_Store
.vscode
*.lock
# Build directories at the repository root (anchored so that files elsewhere
# whose names start with "build", e.g. .github/workflows/build-*.yml, are
# not ignored)
/build*/
# PyPI packaging (setuptools / scikit-build / cibuildwheel)
_deps/
_skbuild/
dist/
wheelhouse/
*.egg-info/
